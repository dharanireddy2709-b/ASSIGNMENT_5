# 12. IMPLEMENTATION USING PYTHON (pgmpy)

## Python Code

```python id="5m5vbf"
from pgmpy.models import BayesianNetwork
from pgmpy.factors.discrete import TabularCPD
from pgmpy.inference import VariableElimination

# Create Bayesian Network
model = BayesianNetwork([
    ('Flu', 'Fever'),
    ('Flu', 'Cough')
])

# Define CPTs
cpd_flu = TabularCPD(
    variable='Flu',
    variable_card=2,
    values=[[0.9], [0.1]]
)

cpd_fever = TabularCPD(
    variable='Fever',
    variable_card=2,
    values=[
        [0.9, 0.2],
        [0.1, 0.8]
    ],
    evidence=['Flu'],
    evidence_card=[2]
)

cpd_cough = TabularCPD(
    variable='Cough',
    variable_card=2,
    values=[
        [0.8, 0.3],
        [0.2, 0.7]
    ],
    evidence=['Flu'],
    evidence_card=[2]
)

# Add CPTs
model.add_cpds(
    cpd_flu,
    cpd_fever,
    cpd_cough
)

# Verify model
print(model.check_model())

# Inference
inference = VariableElimination(model)

result = inference.query(
    variables=['Flu'],
    evidence={
        'Fever': 1,
        'Cough': 1
    }
)

print(result)
```

